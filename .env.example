# Copy this file to .env and set your project-specific image name
IMAGE_NAME=circadia_base

# RStudio auth — set to 'true' to disable password (local dev only)
DISABLE_AUTH=true

# RStudio build profile — controls which Dockerfile is used for the R service
# Options: minimal (default) | no-stan | full
# - minimal:  P3M binaries, no Stan, no lunaR  (~5-8 min)
# - no-stan:  P3M binaries, no Stan, with lunaR (~10-15 min)
# - full:     P3M binaries, Stan + lunaR        (~30-40 min)
RSTUDIO_PROFILE=minimal
