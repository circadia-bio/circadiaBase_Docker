FROM jmgirard/rstudio2u:latest

# r2u + bspm means install.packages() automatically uses apt binaries
# All packages below install as pre-built .deb files — no compilation needed

# ggplot2 extensions
RUN install2.r --error --skipinstalled \
    ggpubr \
    ggrepel \
    ggridges \
    patchwork \
    cowplot \
    scales \
    viridis \
    RColorBrewer

# Stats packages
RUN install2.r --error --skipinstalled \
    lme4 \
    lmerTest \
    emmeans \
    MuMIn \
    effectsize \
    performance \
    parameters \
    see

# Bayesian stats (no Stan)
RUN install2.r --error --skipinstalled \
    bayesplot \
    tidybayes

# Sleep & circadian packages
RUN install2.r --error --skipinstalled \
    GGIR \
    ActCR \
    circacompare \
    cosinor \
    cosinor2

# lunaR — install manually if needed:
# Rscript -e "devtools::install_github('remnrem/luna')"

EXPOSE 8787

CMD ["/init"]
